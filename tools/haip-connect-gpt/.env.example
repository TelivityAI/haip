# --- Upstream HAIP Connect API ---
# Base URL of a running HAIP API instance (the gateway calls /api/v1/connect/* on it).
HAIP_API_BASE_URL=http://localhost:3000
# API key the gateway sends as `x-api-key` to HAIP (matches HAIP's CONNECT_API_KEY).
# The GPT never sees this — the gateway injects it server-side.
HAIP_CONNECT_API_KEY=dev-connect-key

# --- This gateway ---
# Port to listen on for local/Node hosting (ignored on Vercel serverless).
PORT=8080
# Public URL where this gateway is reachable — used as the OpenAPI `servers[0].url`
# and as the base for the privacy page. On Vercel this is auto-derived from the
# deployment domain if left unset; set it to your production domain for a stable spec.
PUBLIC_BASE_URL=http://localhost:8080

# --- Tool-call logging (Supabase project: haip-demo, direct Postgres) ---
# Connection string for the haip_tool_calls table. Leave blank to disable
# logging (gateway still serves normally).
TOOL_LOG_DATABASE_URL=
