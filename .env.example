# HAIP Environment Variables
# Copy to .env for local development

# Database
DATABASE_URL=postgresql://haip:haip@localhost:5432/haip

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
NODE_ENV=development

# Serve bundled UIs from the API container (production / docker-compose demo)
# SERVE_DASHBOARD=true   # dashboard at /
# SERVE_BOOKING=true     # booking engine at /booking/

# In production the API refuses to boot with an insecure config
# (AUTH_ENABLED=false or STRIPE_MODE=mock) to prevent an accidental insecure
# real deployment. The intentional public demo sets this to opt out.
# HAIP_ALLOW_INSECURE=false

# CORS: comma-separated allowlist of browser origins, or '*' for any. When unset,
# production defaults to same-origin only; dev allows all.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Optional brute-force rate limit (in-memory). Defaults: 300 req / 60s per IP.
# RATE_LIMIT_MAX=300
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_DISABLED=false
# Only set true when running behind a trusted proxy/load balancer that sets
# X-Forwarded-For. Off by default so a client can't spoof the header to dodge
# the limit (uses the real socket IP).
# RATE_LIMIT_TRUST_PROXY=false

# Authentication (Keycloak OIDC)
# AUTH_ENABLED controls whether JWT auth is enforced:
#   false (default) — all requests pass through, no JWT required. Use for dev/testing.
#   true            — valid JWT required on all endpoints except @Public().
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080

# Connect API (OTAIP agents) — comma-separated list of valid API keys.
# When AUTH_ENABLED != 'false' and this is unset/empty, ConnectController
# returns 500 (fail closed). When AUTH_ENABLED=false, the guard is bypassed.
# CONNECT_API_KEY=agent1-key,agent2-key
KEYCLOAK_REALM=haip
KEYCLOAK_CLIENT_ID=haip-api
# KEYCLOAK_AUDIENCE — optional explicit override for the expected `aud` claim.
# If unset, KEYCLOAK_CLIENT_ID is used. JWTs whose `aud`/`azp` does not match
# this value are rejected (prevents cross-client token replay within the realm).
# KEYCLOAK_AUDIENCE=haip-api

# Stripe Payment Gateway (legacy default when PAYMENT_GATEWAY is unset)
# STRIPE_MODE controls Stripe selection when PAYMENT_GATEWAY is not set:
#   mock (default) — no HTTP calls, fake success. Use for tests/CI.
#   test           — real Stripe calls in test mode. Requires STRIPE_SECRET_KEY.
#   live           — real charges. Requires STRIPE_SECRET_KEY.
STRIPE_MODE=mock
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Payment gateway provider (authorize/capture/void/refund adapter)
# mock | stripe | adyen | mollie | square | braintree
# When unset: mock if STRIPE_MODE=mock, otherwise stripe.
# PAYMENT_GATEWAY=adyen

# Adyen (when PAYMENT_GATEWAY=adyen)
# ADYEN_API_KEY=
# ADYEN_MERCHANT_ACCOUNT=
# ADYEN_ENV=test
# ADYEN_CHECKOUT_URL=

# Mollie
# MOLLIE_API_KEY=
# MOLLIE_API_BASE=https://api.mollie.com/v2

# Square
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_ENV=sandbox
# SQUARE_API_BASE=

# Braintree
# BRAINTREE_MERCHANT_ID=
# BRAINTREE_PUBLIC_KEY=
# BRAINTREE_PRIVATE_KEY=
# BRAINTREE_ENV=sandbox
# BRAINTREE_API_BASE=

# Media object storage
# STORAGE_DRIVER controls the media upload pipeline:
#   local (default) — uploads disabled; the dashboard uses image-URL paste only.
#                     The demo runs entirely on stock URLs (no object storage).
#   s3              — S3-compatible object storage (AWS S3 or MinIO). Requires
#                     the S3_* vars below. Start MinIO with:
#                       docker compose --profile storage up
STORAGE_DRIVER=local
# S3_BUCKET=haip-media
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000          # MinIO endpoint; omit for AWS S3
# S3_ACCESS_KEY_ID=haip                       # MinIO root user / AWS access key
# S3_SECRET_ACCESS_KEY=haip_secret            # MinIO root password / AWS secret
# S3_FORCE_PATH_STYLE=true                    # true for MinIO; false for AWS S3
# S3_PUBLIC_BASE_URL=                         # optional CDN/public base for object URLs
